# SHWD – Beispielkonfiguration
APP_ENV=production
APP_URL=https://www.shwd.de

# Kontaktformular
MAIL_TRANSPORT=mail
MAIL_TO=support@shwd.de
MAIL_FROM=support@shwd.de
MAIL_FROM_NAME=SHWD
MAIL_SUBJECT_PREFIX=[SHWD]

# Für einen späteren SMTP-Ausbau vorbereitet
SMTP_HOST=smtp.ionos.de
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USERNAME=support@shwd.de
SMTP_PASSWORD=bitte-aendern
