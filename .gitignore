# =========================================================
# SHWD WebSite - .gitignore
# Für statische Website mit HTML/CSS/PHP
# =========================================================

# ---------------------------------------------------------
# Betriebssystem-Dateien
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------
.vscode/
.idea/
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------
# Umgebungsdateien / sensible Konfiguration
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# PHP / Composer
# ---------------------------------------------------------
vendor/
composer.phar
.phpunit.result.cache

# ---------------------------------------------------------
# Cache / temporäre Dateien
# ---------------------------------------------------------
tmp/
temp/
cache/
*.tmp
*.temp

# ---------------------------------------------------------
# Frontend-Tooling (nur relevant, falls später genutzt)
# ---------------------------------------------------------
node_modules/
dist/
build/

# ---------------------------------------------------------
# Lokale Uploads / generierte Dateien
# ---------------------------------------------------------
uploads/